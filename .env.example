# TacticalTickets — local development (copy to .env or run: python scripts/setup_network_ports.py)
# Production: set these on the host/container/process manager — do not rely on the Network settings UI.

# --- Local only (this computer) ---
# BACKEND_HOST=127.0.0.1
# BACKEND_PORT=8000
# FRONTEND_HOST=127.0.0.1
# FRONTEND_PORT=5173
# VITE_API_BASE_URL=
# ALLOWED_HOSTS_USE_WILDCARD=0

# --- LAN sharing (other devices on same network) ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_HOST=0.0.0.0
FRONTEND_PORT=5174
LAN_IP=192.168.1.55
FRONTEND_LAN_URL=http://192.168.1.55:5174
ALLOWED_HOSTS_USE_WILDCARD=1
VITE_API_BASE_URL=http://192.168.1.55:8000/api/

# Derived (updated by install / Network settings API)
FRONTEND_BASE_URL=http://192.168.1.55:5174
API_BASE_URL=http://192.168.1.55:8000/api/
VITE_BACKEND_HOST=127.0.0.1
VITE_BACKEND_PORT=8000
VITE_FRONTEND_HOST=0.0.0.0
VITE_FRONTEND_PORT=5174

# CORS: localhost, 127.0.0.1, and LAN IP (also FRONTEND_LAN_URL)
# CORS_EXTRA_ORIGINS=http://192.168.1.55:5174,http://localhost:5174,http://127.0.0.1:5174

# Secure ALLOWED_HOSTS (no wildcard) — set ALLOWED_HOSTS_USE_WILDCARD=0 and LAN_IP above
# ALLOWED_HOSTS_EXTRA=extra.host.example
